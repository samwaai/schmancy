{
	"name": "@mhmo91/schmancy",
	"version": "0.10.4",
	"description": "UI library build with web components",
	"main": "./dist/index.js",
	"customElements": "custom-elements.json",
	"exports": {
		".": {
			"types": "./types/src/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		},
		"./mixins": {
			"types": "./types/mixins/index.d.ts",
			"default": "./mixins/index.ts"
		},
		"./agent": {
			"types": "./types/src/agent/agent-entry.d.ts",
			"import": "./dist/agent/schmancy.agent.js",
			"default": "./dist/agent/schmancy.agent.js"
		},
		"./agent/manifest": "./dist/agent/schmancy.manifest.json",
		"./vite": "./plugins/vite-plugin-schmancy-auto-import.ts",
		"./*": {
			"types": "./types/src/*/index.d.ts",
			"default": "./dist/*.js"
		}
	},
	"packageManager": "yarn@4.9.2",
	"repository": {
		"type": "git",
		"url": "https://github.com/samwaai/schmancy.git"
	},
	"keywords": [
		"lit",
		"UI",
		"Schmancy",
		"agent-runtime",
		"esm",
		"sandbox",
		"web-components"
	],
	"type": "module",
	"types": "./types/src/index.d.ts",
	"module": "./dist/index.js",
	"files": [
		"dist",
		"types",
		"src",
		".claude-plugin",
		"plugins",
		"skills",
		"custom-elements.json",
		"README.md"
	],
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"scripts": {
		"dev": "vite build --config vite.config.ts --watch",
		"build": "tsc && vite build --config vite.config.ts && yarn manifest && yarn build:agent && yarn build:handover",
		"build:agent": "vite build --config vite.config.agent.ts",
		"build:handover": "node scripts/render-handover.mjs",
		"manifest": "wca 'src/**/*.ts' --outFile custom-elements.json --format json",
		"ncu": "ncu -u && npm i",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint src/ mixins/",
		"lit-check": "lit-analyzer 'src/**/*.ts'",
		"check": "yarn typecheck && yarn lint && yarn lit-check && yarn knip",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"knip": "knip",
		"format": "prettier --write 'src/**/*.{ts,css,scss}' 'mixins/**/*.{ts,css}'",
		"format:check": "prettier --check 'src/**/*.{ts,css,scss}' 'mixins/**/*.{ts,css}'"
	},
	"author": "@mhmo91",
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/samwaai/schmancy/issues"
	},
	"homepage": "https://github.com/samwaai/schmancy#readme",
	"dependencies": {
		"@floating-ui/dom": "^1.7.6",
		"@lit-labs/motion": "^1.1.0",
		"@lit-labs/signals": "^0.2.0",
		"@lit-labs/virtualizer": "^2.1.1",
		"@lit/context": "^1.1.6",
		"@material/material-color-utilities": "^0.4.0",
		"@material/web": "^2.4.1",
		"cleave.js": "^1.6.0",
		"dayjs": "^1.11.20",
		"highlight.js": "^11.11.1",
		"immer": "^11.1.4",
		"jsqr": "^1.4.0",
		"lit": "^3.3.2",
		"rxjs": "^7.8.2",
		"ts-is-present": "^1.2.2"
	},
	"devDependencies": {
		"@rollup/plugin-strip": "^3.0.4",
		"@rollup/plugin-terser": "^1.0.0",
		"@tailwindcss/postcss": "^4.2.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/cleave.js": "^1.4.12",
		"@types/node": "^25.5.0",
		"@vitest/browser-playwright": "^4.1.4",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.0",
		"axe-core": "^4.11.3",
		"happy-dom": "^20.8.4",
		"knip": "^6.6.0",
		"lit-analyzer": "^2.0.3",
		"oxlint": "^1.61.0",
		"playwright": "^1.59.1",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"rollup-plugin-copy": "^3.5.0",
		"sass": "^1.98.0",
		"tailwindcss": "^4.2.1",
		"ts-lit-plugin": "^2.0.2",
		"ts-morph": "^28.0.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.0",
		"web-component-analyzer": "^2.0.0"
	},
	"peerDependencies": {
		"@lit/context": "^1.1.0",
		"immer": "^11.0.0",
		"lit": "^3.2.1",
		"rxjs": "^7.8.0",
		"tailwindcss": "^4.0.0"
	}
}
