{
	"compilerOptions": {
		"target": "ES2023",
		"experimentalDecorators": true,
		"useDefineForClassFields": false,
		"module": "ESNext",
		"lib": ["ES2023", "ESNext.Disposable", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		/* Bundler mode */
		"moduleResolution": "node",
		"isolatedModules": false,
		"noEmit": false,
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationDir": "types",
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		/* Linting */
		"strict": false,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"baseUrl": ".",
		"paths": {
			"@schmancy/input": ["./src/form/fields/input"],
			"@schmancy/input/*": ["./src/form/fields/input/*"],
			"@schmancy/textarea": ["./src/form/fields/textarea"],
			"@schmancy/textarea/*": ["./src/form/fields/textarea/*"],
			"@schmancy/select": ["./src/form/fields/select"],
			"@schmancy/select/*": ["./src/form/fields/select/*"],
			"@schmancy/autocomplete": ["./src/form/fields/autocomplete"],
			"@schmancy/autocomplete/*": ["./src/form/fields/autocomplete/*"],
			"@schmancy/checkbox": ["./src/form/fields/checkbox"],
			"@schmancy/checkbox/*": ["./src/form/fields/checkbox/*"],
			"@schmancy/switch": ["./src/form/fields/switch"],
			"@schmancy/switch/*": ["./src/form/fields/switch/*"],
			"@schmancy/radio-group": ["./src/form/fields/radio-group"],
			"@schmancy/radio-group/*": ["./src/form/fields/radio-group/*"],
			"@schmancy/date-range": ["./src/form/fields/date-range"],
			"@schmancy/date-range/*": ["./src/form/fields/date-range/*"],
			"@schmancy/range": ["./src/form/fields/range"],
			"@schmancy/range/*": ["./src/form/fields/range/*"],
			"@schmancy/*": ["./src/*"],
			"@mixins/*": ["./mixins/*"]
		},
		"plugins": [
			{
				"name": "ts-lit-plugin",
				"strict": true,
				"rules": {
					"no-unknown-tag-name": "error",
					"no-unknown-event": "warning",
					"no-unknown-attribute": "warning",
					"no-invalid-attribute": "warning",
					"no-invalid-event": "warning",
					"no-invalid-property": "warning",
					"no-invalid-attribute-value": "warning",
					"no-invalid-css": "off",
					"no-missing-import": "off",
					"no-unknown-slot": "off"
				}
			}
		]
	},
	"types": ["vitest/globals"],
	"include": ["src/**/*.ts", "typings/**/*.d.ts", "mixins/**/*.ts", "mixins/**/*.d.ts"],
	"exclude": ["types", "dist", "node_modules"]
}
