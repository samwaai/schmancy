# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs — regenerated by `yarn build`. The npm package still ships
# them via the `files` array in package.json; the github-actions release
# workflow rebuilds before `npm publish`. Monorepo consumers (web/) pick
# up dist/ via the turbo build pipeline.
dist/
dist-ssr/

# Local environment files
*.local

# Node modules (even though Yarn PnP doesn’t use a node_modules folder, include for completeness)
node_modules/

# Yarn v2+/PnP configuration and cache
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# Yarn Plug'n'Play files are essential and should be committed
# (Do not add any rules to ignore .pnp.* files)

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


.pnp.*
.yarn/cache
node_modules/  # In the root .gitignore
functions/node_modules/ # This is also important.

**/.claude/settings.local.json

# Local Netlify folder
.netlify

# Demo directory (local development only, not part of the library)
demo/

# Vitest browser-mode artifacts (screenshot diffs, snapshots from failed runs)
.vitest-attachments/
**/__screenshots__/
