# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local environment files
*.local

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Node + Yarn 4 (node-modules linker per .yarnrc.yml)
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
# yarn.lock — schmancy is consumed both standalone (publish workflow
# uses `--no-immutable`, writes a fresh lockfile every run) and via the
# parent monorepo (web/ imports the package, not the submodule's
# install graph). Tracking the lockfile produced constant drift on
# every local install. Rebuilt by CI on each publish.
yarn.lock

# Tooling caches
.turbo/

# Vitest browser-mode artifacts (screenshot diffs, snapshots from failed runs)
.vitest-attachments/
**/__screenshots__/

# Local Netlify
.netlify

# Demo directory (local development only, not part of the library)
demo/

# Throwaway prototypes / spikes — never committed
_scratch/

# Local Claude settings (per-developer, not shared)
**/.claude/settings.local.json

# Build outputs — regenerated by `yarn build`. The npm package still
# ships them via the `files` array in package.json; the publish
# workflow rebuilds before `npm publish`. Monorepo consumers (web/)
# pick up dist/ via the Turbo build pipeline.
#
# tsc → types/ (declarationDir + emitDeclarationOnly)
# vite build → dist/
# yarn manifest → custom-elements.json
# yarn build:handover → dist/handover/
dist/
types/
custom-elements.json
